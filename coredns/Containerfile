FROM quay.io/hummingbird/core-runtime:2.42-builder@sha256:d44e1ed2dd1e1770836254fefb40af913def348ac2c6e31eae3849a529bb58ca AS builder

ARG VERSION=1.14.3

USER 0
RUN dnf install -y tar gzip && \
  curl -L https://github.com/coredns/coredns/releases/download/v${VERSION}/coredns_${VERSION}_linux_amd64.tgz | tar zxvf - && \
  ls -al coredns

FROM quay.io/hummingbird/core-runtime:2.42@sha256:9666b5aad217d503660028879a72d4a500fbcbff89fcad5d1974e029eb5df4d3

COPY --from=builder /tmp/coredns /usr/local/bin/coredns

WORKDIR /etc/coredns
ENTRYPOINT ["coredns"]
