FROM quay.io/hummingbird/core-runtime:2.42-builder@sha256:2327c189088ceb641ade5bf9d1252b580e9eafde3a39fcbec64161d4d783bdf1 AS builder

ARG VERSION=1.14.4

USER 0
RUN dnf install -y tar gzip && \
  curl -L https://github.com/coredns/coredns/releases/download/v${VERSION}/coredns_${VERSION}_linux_amd64.tgz | tar zxvf - && \
  ls -al coredns

FROM quay.io/hummingbird/core-runtime:2.42@sha256:82ab1238082f405e19e1cc6e4950549371b6742ba6b649ca356c058249162540

COPY --from=builder /tmp/coredns /usr/local/bin/coredns

WORKDIR /etc/coredns
ENTRYPOINT ["coredns"]
