FROM quay.io/hummingbird/core-runtime:2.42-builder@sha256:f1e680c22d41bd9ec206ad9750bd420e9b4f0c8c1c19b78ee7793024b7b44027 AS builder

ARG VERSION=1.14.3

USER 0
RUN dnf install -y tar gzip && \
  curl -L https://github.com/coredns/coredns/releases/download/v${VERSION}/coredns_${VERSION}_linux_amd64.tgz | tar zxvf - && \
  ls -al coredns

FROM quay.io/hummingbird/core-runtime:2.42@sha256:c2b8b0a4b588ce91b058b89dc6d50b6049b11dd879e98697974c92c0c6325026

COPY --from=builder /tmp/coredns /usr/local/bin/coredns

WORKDIR /etc/coredns
ENTRYPOINT ["coredns"]
