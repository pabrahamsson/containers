FROM registry.access.redhat.com/ubi10/ubi-minimal:10.1-1774545417@sha256:7bd3d2e7f5c507aebd1575d0f2fab9fe3e882e25fee54fa07f7970aa8bbc5fab

ARG VERSION=2.89.0

RUN  microdnf upgrade --refresh -y && \
  microdnf install -y jq git && \
  curl -LO https://github.com/cli/cli/releases/download/v${VERSION}/gh_${VERSION}_linux_amd64.rpm && \
  rpm -Uvh gh_${VERSION}_linux_amd64.rpm && rm gh_${VERSION}_linux_amd64.rpm && \
  microdnf clean all && \
  gh version && \
  jq --version && \
  git --version

CMD ["bash"]
