# Build stage
FROM quay.io/hummingbird/nodejs:26-builder@sha256:cc4d4a6af58182daba5b70654b7bf306b80bbf3d2ab6fd28650850ea3450221f AS builder

ARG VERSION=17.6.1

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:26@sha256:bc4e806eb595703efbed44045f1ed1315598fcf146cb72691446d891ab88a539

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
