# Build stage
FROM quay.io/hummingbird/nodejs:25-builder@sha256:1927bb86114670b21a745de40393b6e7415b096d0ca8d39613ff45b62ceef795 AS builder

ARG VERSION=17.6.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:25@sha256:c437ac70b7645ed2c740f2993ec9779202b583f90a72891b0b4c04c604ae0066

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
