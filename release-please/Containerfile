# Build stage
FROM quay.io/hummingbird/nodejs:26-builder@sha256:cb47b05f38e542eef423e4c631a5f6c3863f66edfffd6009d7c5a093de450942 AS builder

ARG VERSION=17.6.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:26@sha256:43a55926363f2db8c4df1064f6215b68e849f99309befdbd394519ea02f50e8a

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
