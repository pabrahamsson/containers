# Build stage
FROM quay.io/hummingbird/nodejs:26-builder@sha256:735aa42655aace9a9af79d8560719f7ef66acfd12e47fe462bbd36dc41da22f7 AS builder

ARG VERSION=17.9.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:26@sha256:65343cc005d16fd207243f3b6447bb01ddc9369bb1b7a7831279c6e8d6ad1774

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
