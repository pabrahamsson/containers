# Build stage
FROM quay.io/hummingbird/nodejs:25-builder@sha256:804d175572801b2a52e58bc5eb587b9a0c7a2e150bfb86aefacaa28793879043 AS builder

ARG VERSION=17.6.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:25@sha256:51a8e75fe4566ba4e0afde1b6317742b3b4c5153203ebce0d315e09fc43d3cf5

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
