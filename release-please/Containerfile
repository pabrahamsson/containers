# Build stage
FROM quay.io/hummingbird/nodejs:26-builder@sha256:5e7f1571c33a1d0b22db314326eee74e9305e42889446b78f4ce6d5876f68185 AS builder

ARG VERSION=17.10.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:26@sha256:f67120162acad6d209d57c98de4c9513ad78e92fd13d1be263208e96238870cc

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
