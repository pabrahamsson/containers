# Build stage
FROM quay.io/hummingbird/nodejs:26-builder@sha256:e02cf7c070c987e63d122f58b67982eea33b2158079a0c7f518aa37a39211600 AS builder

ARG VERSION=17.6.1

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:26@sha256:fbba604501687c5c6e50c1928feae9d5644c9978fd9152b440093d97b25216d8

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
