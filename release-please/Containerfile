# Build stage
FROM quay.io/hummingbird/nodejs:26-builder@sha256:4cbd931147fa3cce546d3fe2e08eb735b782cca964083283c0b95347f77e65d7 AS builder

ARG VERSION=17.9.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:26@sha256:134a8274958fe2ef1d91fce8bdcf7f202eb7d9e125cba5b76b004db278333ab4

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
