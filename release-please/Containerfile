# Build stage
FROM quay.io/hummingbird/nodejs:25-builder@sha256:8590a76e11ccbf14fede0acf4499bc3706ebb6b4332b13935f60fa1de347a697 AS builder

ARG VERSION=17.3.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:25@sha256:a145736bc4b82339fac453b31f742940a3352aa7c98fd46f3d1a439cb23e0975

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
