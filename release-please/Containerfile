# Build stage
FROM quay.io/hummingbird/nodejs:25-builder@sha256:35fd00d6c4aae4103f9202090aa2f57aa4b3c66b71f630fcd4fc940465183265 AS builder

ARG VERSION=17.6.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:25@sha256:913b529c412128d7ad81ccca4a85329d6cc96e5d4a275c3025dfdf62998cb628

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
