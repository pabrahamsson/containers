# Build stage
FROM quay.io/hummingbird/nodejs:26-builder@sha256:178217b2b68adf8f2a2828ec180b0fb2a0e5d530448cd1cba3409a5b229604d6 AS builder

ARG VERSION=17.6.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:26@sha256:75c6f8ae944b45e0a10c0252e32c05a020b805a15223cff9e66d336179a14fa3

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
