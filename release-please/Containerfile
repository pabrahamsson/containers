# Build stage
FROM quay.io/hummingbird/nodejs:25-builder@sha256:d7d88dc66d2143caf72d14ca2b706e3144f809fd8245f6c4b82a994e3e935771 AS builder

ARG VERSION=17.6.0

# Install jq + deps
USER root
RUN dnf install -y jq && \
  dnf clean all -y

# Runtime stage
FROM quay.io/hummingbird/nodejs:25@sha256:70004b43de710f7d0f61fd05c1e45c6fabdcebaaf0e2e750fc6b3d67990b78f9

USER root
RUN npm i release-please@${VERSION} -g && \
  release-please --version
USER ${CONTAINER_DEFAULT_USER}

# Copy jq + deps from builder
COPY --from=builder /usr/bin/jq /usr/bin/jq
COPY --from=builder /usr/lib64/libjq* /usr/lib64/
COPY --from=builder /usr/lib64/libonig* /usr/lib64/

ENTRYPOINT ["release-please"]
